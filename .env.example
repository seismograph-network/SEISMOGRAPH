# .env.example
# SEISMOGRAPH Gateway — Environment Variable Reference
# ====================================================
# Copy this file to .env and edit the values before running the stack.
#
#   cp .env.example .env
#   # edit .env as needed
#   docker-compose up --build
#
# All variables have safe defaults for local development.
# Production deployments MUST set STORAGE_BACKEND and QUORUM_BACKEND.

# ---------------------------------------------------------------------------
# Storage backend
# ---------------------------------------------------------------------------

# Which time-series store to use for signal batches and drift alerts.
#
# Values:
#   sqlite      -- local SQLite file (default; development and single-node
#                  evaluation only; not suitable for production or
#                  multi-instance deployments)
#   clickhouse  -- ClickHouse cluster (production; required for Phase 2+
#                  multi-tenant deployments)
#
STORAGE_BACKEND=sqlite

# SQLite database file path.
# Only used when STORAGE_BACKEND=sqlite.
# Path is relative to the working directory inside the container (/app).
#
SEISMOGRAPH_DB_URL=sqlite:///seismograph.db

# ClickHouse connection DSN.
# Only used when STORAGE_BACKEND=clickhouse.
# Format: clickhouse://<host>:<port>/<database>
# In the docker-compose stack the host is the service name "clickhouse".
#
CLICKHOUSE_URL=clickhouse://clickhouse:9000/default

# ---------------------------------------------------------------------------
# Quorum backend
# ---------------------------------------------------------------------------

# Which backend stores the cross-observer quorum state for AgreementScorer.
#
# Values:
#   memory  -- in-process Python dict (default; single-instance only;
#               state is lost on restart)
#   redis   -- Redis Set per model_tuple (production; supports multiple
#               gateway replicas; state survives gateway restarts)
#
QUORUM_BACKEND=memory

# Redis connection URL.
# Only used when QUORUM_BACKEND=redis.
# Format: redis://<host>:<port>/<db>
# In the docker-compose stack the host is the service name "redis".
#
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Audit export auth
# ---------------------------------------------------------------------------

# Bearer token required to access GET /v1/alerts/{alert_id}/export.
# If unset, the endpoint returns 503 (administratively disabled).
# Set a strong random value in production:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#
SEISMOGRAPH_EXPORT_TOKEN=
